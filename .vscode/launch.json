    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Node Server",
            "type": "pwa-node",
            "request": "launch",
            "program": "${workspaceFolder}/server.js",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost",
            "url": "http://localhost:8010",
            "webRoot": "${workspaceFolder}"
        }
    ]
}